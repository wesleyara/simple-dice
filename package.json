{
  "name": "simple-dice",
  "version": "1.0.2",
  "description": "A simple dice rolling library for JavaScript and TypeScript.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "dev": "ts-node src/index.ts",
    "build": "rimraf lib && tsc --declaration",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky install"
  },
  "lint-staged": {
    "src/**/*.{js,ts,jsx,tsx}": [
      "eslint . --fix"
    ]
  },
  "files": [
    "lib/**/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wesleyara/simple-dice.git"
  },
  "keywords": [
    "typescript",
    "javascript"
  ],
  "author": "wesleyara",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wesleyara/simple-dice/issues"
  },
  "homepage": "https://github.com/wesleyara/simple-dice#readme",
  "dependencies": {
    "axios": "^1.13.5",
    "rimraf": "^3.0.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.3.0",
    "@commitlint/config-conventional": "^17.1.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.17",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^8.0.2",
    "lint-staged": "^13.0.4",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
